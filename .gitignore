# Ignore everything under .claude/ except the load-bearing CI/lint scripts.
# `.claude/*` (not `.claude/`) keeps the directory itself traversable so
# the per-file re-includes below are actually evaluated.
.claude/*
!.claude/scripts/
.claude/scripts/*
