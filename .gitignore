CLAUDE.local.md
# Ignore everything under .claude/ except the load-bearing CI/lint scripts.
# `.claude/*` (not `.claude/`) keeps the directory itself traversable so
# the per-file re-includes below are actually evaluated.
.claude/*
!.claude/scripts/
.claude/scripts/*
!.claude/scripts/coverage-percent.sh
!.claude/scripts/coverage-gate.sh
!.claude/scripts/publish-coverage.sh
!.claude/scripts/audit-log-status.sh
!.claude/scripts/audit-log-labels.sh
!.claude/scripts/audit-test-isolation.sh
!.claude/scripts/audit-test-spawn-retry.sh
!.claude/scripts/audit-job-timeouts.sh
!.claude/scripts/audit-repo-identity.sh
!.claude/scripts/audit-gate-mirror.sh
!.claude/scripts/audit-workflow-lockstep.sh
!.claude/scripts/test-os.sh
!.claude/scripts/test-os-winserver.ps1
!.claude/scripts/test-os-suite.sh
# Coverage artifact emitted by `task coverage:check`.
cobertura.xml

# Hermetic dist tree emitted by `task check:determinism --preserve-dist` (CI's
# `preserved-dist` path). Local runs write it into the repo root.
/preserved-dist/
/preserved-dist-*/
.tokensave
