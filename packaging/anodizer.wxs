<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX v3-dialect source for anodizer's Windows .msi installer. The v3 namespace
  (schemas.microsoft.com/wix/2006/wi) is the dialect understood by BOTH the
  Linux-native `wixl` (msitools) builder used on CI and a real WiX v3 toolchain
  on Windows, so one source file covers every host. anodizer renders this through
  its template engine first: {{ ProjectName }}, {{ Version }}, {{ MsiVersion }}
  (the numeric major.minor.patch core of Version — WiX rejects a pre-release /
  build-metadata suffix in Product/@Version), {{ MsiArch }} (x64/x86/arm64),
  {{ BinaryPath }} (absolute path to the built .exe) and {{ MsiProductCode }}
  (deterministic ProductCode GUID) are substituted per published crate/target
  before the MSI is built.

  UpgradeCode is a FIXED GUID: it must stay stable across releases so Windows
  Installer recognises a new .msi as an upgrade of the prior install.
  Product Id is the deterministic MsiProductCode var: a UUIDv5 over
  {ProjectName}\0{Version}\0{MsiArch} (namespace = this UpgradeCode), stable for
  a given version+arch but rotating per version — Windows treats each version as
  a distinct product that UpgradeCode + MajorUpgrade relate. This replaces the
  former Id="*" (random per build) so winget's AppsAndFeaturesEntries can detect
  upgrades.

  Determinism note: a pinned ProductCode does NOT make the .msi byte-reproducible
  — wixl/WiX rotate the PackageCode and the summary-information stream timestamps
  on every build (msitools/WiX #8978), so the MSI stays in the non-reproducible
  classification of the determinism allowlist regardless of this change.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="{{ MsiProductCode }}"
           Name="{{ ProjectName }}"
           Language="1033"
           Version="{{ MsiVersion }}.0"
           Manufacturer="TJ Smith"
           UpgradeCode="6f3a2b1c-0d4e-5a6b-7c8d-9e0f1a2b3c4d">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Manufacturer="TJ Smith"
             Description="{{ ProjectName }} {{ Version }} ({{ MsiArch }}) installer"
             Comments="A Rust-native release automation tool" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Block downgrades and de-duplicate concurrent installs of the same line. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of {{ ProjectName }} is already installed." />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="{{ ProjectName }}">
          <Component Id="MainExecutable" Guid="*">
            <File Id="anodizerExe"
                  Name="{{ ProjectName }}.exe"
                  Source="{{ BinaryPath }}"
                  KeyPath="yes" />
            <!-- Put the install dir on the system PATH so the CLI is invocable
                 from any shell after install. Action=set Part=last appends
                 INSTALLFOLDER to the machine (System=yes) PATH; Windows
                 Installer removes the same entry on uninstall (Permanent=no). -->
            <Environment Id="UpdatePath"
                         Name="PATH"
                         Value="[INSTALLFOLDER]"
                         Permanent="no"
                         Part="last"
                         Action="set"
                         System="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="{{ ProjectName }}" Level="1">
      <ComponentRef Id="MainExecutable" />
    </Feature>
  </Product>
</Wix>
